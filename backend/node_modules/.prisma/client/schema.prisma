// Prisma Schema for My World Marketplace (SQLite Compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id         String  @id @default(cuid())
  email      String  @unique
  phone      String? @unique
  password   String
  fullName   String
  role       String  @default("CUSTOMER") // ADMIN, SELLER, MANAGER, DRIVER, CUSTOMER
  avatar     String?
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)
  language   String  @default("ar") // ar, fr, en

  // Location for GPS
  latitude  Float?
  longitude Float?
  address   String?

  // Driver-specific fields
  driverStatus  String? @default("AVAILABLE") // AVAILABLE, BUSY, OFFLINE
  driverLicense String?
  vehicleType   String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stores        Store[]        @relation("SellerStores")
  managedStores StoreManager[]
  orders        Order[]        @relation("CustomerOrders")
  deliveries    Delivery[]     @relation("DriverDeliveries")
  subscriptions Subscription[]
  loyaltyPoints LoyaltyPoint[]
  notifications Notification[]

  @@index([email])
  @@index([phone])
  @@index([role])
}

// ============================================
// STORE & PRODUCTS
// ============================================

model Category {
  id          String  @id @default(cuid())
  name        String
  nameAr      String // Arabic name
  nameFr      String // French name
  icon        String?
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stores   Store[]
  products Product[]

  @@index([name])
}

model Store {
  id       String @id @default(cuid())
  sellerId String
  seller   User   @relation("SellerStores", fields: [sellerId], references: [id])

  name        String
  nameAr      String?
  description String?
  logo        String?
  coverImage  String?

  // Category
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Location
  address   String
  city      String
  latitude  Float
  longitude Float

  // Business Info
  phone        String?
  email        String?
  workingHours String? // JSON string for working hours

  // Ratings & Stats
  rating      Float @default(0)
  totalOrders Int   @default(0)

  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  managers   StoreManager[]
  products   Product[]
  orderItems OrderItem[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@index([city])
}

model StoreManager {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  canEditProducts  Boolean @default(true)
  canManageOrders  Boolean @default(true)
  canViewAnalytics Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([storeId, userId])
}

model Product {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  name        String
  nameAr      String?
  description String?

  price     Float
  salePrice Float?

  // Inventory
  stock Int     @default(0)
  sku   String?

  // Images (JSON string array)
  images String @default("[]")

  // Product attributes (for clothes sizes, perfume scents, etc.)
  attributes String? // JSON string

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderItems OrderItem[]

  @@index([storeId])
  @@index([categoryId])
  @@index([name])
}

// ============================================
// ORDERS & DELIVERY
// ============================================

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique @default(cuid())

  // Customer (nullable for guest checkout)
  customerId String?
  customer   User?   @relation("CustomerOrders", fields: [customerId], references: [id])

  // Guest info
  guestName  String?
  guestPhone String?
  guestEmail String?

  // Delivery Address
  deliveryAddress   String
  deliveryLatitude  Float
  deliveryLongitude Float

  // Order Details
  subtotal    Float
  deliveryFee Float @default(0)
  total       Float

  status String  @default("PENDING") // PENDING, PREPARING, READY, PICKED_UP, DELIVERED, CANCELLED
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items      OrderItem[]
  delivery   Delivery?
  commission Commission?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  quantity   Int
  unitPrice  Float
  totalPrice Float

  // Status per store (for multi-store orders)
  status String @default("PENDING")

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([storeId])
}

model Delivery {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  driverId String?
  driver   User?   @relation("DriverDeliveries", fields: [driverId], references: [id])

  status String @default("PENDING") // PENDING, ASSIGNED, PICKED_UP, IN_TRANSIT, DELIVERED, FAILED

  // Tracking
  pickupTime   DateTime?
  deliveryTime DateTime?

  // Cash handling
  cashCollected    Float?
  cashPaidToSeller Float?

  // Driver location tracking
  currentLatitude  Float?
  currentLongitude Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([status])
}

// ============================================
// COMMISSION & FINANCE
// ============================================

model Commission {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  orderTotal       Float
  commissionRate   Float // Percentage
  commissionAmount Float
  sellerPayout     Float

  isPaid Boolean   @default(false)
  paidAt DateTime?

  createdAt DateTime @default(now())

  @@index([isPaid])
}

model CommissionSettings {
  id         String @id @default(cuid())
  percentage Float  @default(10)
  minAmount  Float  @default(0)
  maxAmount  Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique // e.g., "site_config"
  value String // JSON string containing all settings

  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ============================================
// SUBSCRIPTIONS (GYM, CLUBS, etc.)
// ============================================

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type        String  @default("GYM") // GYM, CLUB, MEMBERSHIP
  name        String
  description String?

  price    Float
  duration Int // Duration in days

  startDate DateTime
  endDate   DateTime

  status String @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED

  // QR Code for gym entry
  qrCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// LOYALTY & NOTIFICATIONS
// ============================================

model LoyaltyPoint {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  points  Int
  source  String // "order", "referral", "bonus"
  orderId String?

  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  titleAr String?
  body    String
  bodyAr  String?

  type String // "order", "delivery", "promo", "system"
  data String? // JSON for extra data

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

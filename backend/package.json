{
  "name": "my-world-backend",
  "version": "1.0.0",
  "description": "Backend API for My World Multi-Store Marketplace",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest"
  },
  "keywords": [
    "marketplace",
    "algeria",
    "ecommerce"
  ],
  "author": "My World Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@prisma/client": "^5.10.0",
    "@types/multer-s3": "^3.0.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.11.16",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}